<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/dg_ia_tv_title_input"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="მონაცემების შეყვანა"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <EditText
        android:id="@+id/dg_ia_et_income"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="შემოსავალი"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/dg_ia_tv_title_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <EditText
        android:id="@+id/dg_ia_et_expenses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="ხარჯები"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/dg_ia_et_income"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/dg_ia_btn_save"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="შენახვა"
        app:layout_constraintTop_toBottomOf="@id/dg_ia_et_expenses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
